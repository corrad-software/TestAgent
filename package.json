{
  "name": "test-agent",
  "version": "1.0.0",
  "description": "AI-powered Playwright test agent",
  "main": "dist/agent.js",
  "scripts": {
    "build": "tsc && npm run build:client",
    "start": "ts-node src/server.ts",
    "dev": "concurrently \"ts-node --watch src/server.ts\" \"npm --prefix client run dev\"",
    "scenario:login": "ts-node scenarios/login.ts",
    "build:client": "npm --prefix client run build",
    "dev:api": "ts-node --watch src/server.ts",
    "dev:ui": "npm --prefix client run dev",
    "db:migrate": "npx prisma migrate dev",
    "db:studio": "npx prisma studio",
    "db:seed": "ts-node scripts/migrate-json-to-db.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@prisma/adapter-better-sqlite3": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.0.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "playwright": "^1.40.0",
    "prisma": "^7.6.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.2.1",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  }
}
