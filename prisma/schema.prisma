generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  modules Module[]
  members Member[]
  roles   ProjectRole[]
}

model Member {
  id        String   @id @default(cuid())
  projectId String
  name      String
  email     String
  role      String   @default("Tester")
  avatarUrl String?
  createdAt DateTime @default(now())

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scenarios Scenario[] @relation("ScenarioAssignee")

  @@unique([projectId, email])
}

model Module {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scenarios Scenario[]
}

model Scenario {
  id            String   @id @default(cuid())
  moduleId      String
  assigneeId    String?
  roleId        String?
  testCaseId    String?
  scenarioRefId String?
  name          String
  url           String
  testTypes     String
  description   String?
  tags          String   @default("[]")
  authConfig    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  module   Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  assignee Member?      @relation("ScenarioAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  role     ProjectRole? @relation(fields: [roleId], references: [id], onDelete: SetNull)
  runs     RunRecord[]
}

model ProjectRole {
  id        String   @id @default(cuid())
  projectId String
  name      String
  color     String   @default("gray")
  createdAt DateTime @default(now())

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scenarios Scenario[]

  @@unique([projectId, name])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("Admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model RunRecord {
  id         String   @id @default(cuid())
  scenarioId String
  runAt      DateTime @default(now())
  passed     Boolean
  summary    String
  reportId   String?
  durationMs Int

  scenario Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
}
