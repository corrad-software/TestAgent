# ─── TestAgent Configuration ──────────────────────────────────────────────────

# Anthropic API Key (optional — only needed for AI assertions & failure analysis)
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Server port (default: 4000)
PORT=4000

# JWT secret (change this in production!)
JWT_SECRET=testagent-dev-secret-change-in-prod

# Database URL (SQLite, relative to prisma/ directory)
DATABASE_URL="file:./data/testAgent.db"
